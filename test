<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Our Story - Wedding Page</title>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@300;500;700&family=Shippori+Mincho&display=swap" rel="stylesheet">
    <style>
        :root {
            --color-bg: #ffffff; 
            --color-text: #4a4238; 
            --color-accent: #8ba88e; 
            --color-line: #d1c7bc; 
            --font-serif: "Shippori Mincho", "Noto Serif JP", serif;
            --transition: all 0.4s cubic-bezier(0.25, 1, 0.5, 1);
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            background-color: var(--color-bg);
            color: var(--color-text);
            font-family: var(--font-serif);
            line-height: 1.8;
            overflow-x: hidden;
            -webkit-font-smoothing: antialiased;
        }

        .fade-in { animation: fadeIn 1s ease forwards; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

        header.section-header {
            text-align: center;
            margin-bottom: 60px;
            padding-top: 40px;
            letter-spacing: 0.15em;
        }

        header.section-header h1 { font-weight: 500; font-size: 1.8rem; margin-bottom: 12px; text-transform: uppercase; }
        header.section-header p { font-size: 0.9rem; opacity: 0.7; }

        .section-timeline { max-width: 650px; margin: 0 auto; padding: 20px 20px 80px; }
        .timeline-container { position: relative; width: 100%; max-width: 500px; margin: 0 auto; }
        .timeline-line { position: absolute; left: 20px; top: 0; bottom: 0; width: 1px; background-color: var(--color-line); }

        .timeline-item {
            position: relative;
            padding: 25px 20px 25px 60px;
            margin-bottom: 15px;
            cursor: pointer;
            border-radius: 12px;
            transition: var(--transition);
            display: flex;
            justify-content: space-between;
            align-items: center;
            outline: none;
        }

        .timeline-item:hover, .timeline-item:focus { background-color: rgba(139, 168, 142, 0.08); transform: translateX(8px); }
        .timeline-marker { position: absolute; left: 14px; top: 50%; transform: translateY(-50%); width: 12px; height: 12px; background-color: var(--color-bg); border: 1px solid var(--color-accent); border-radius: 50%; z-index: 2; }
        .timeline-marker::after { content: ''; position: absolute; top: -1px; left: -1px; width: 100%; height: 100%; border-radius: 50%; border: 1px solid var(--color-accent); animation: pulse 2.5s infinite; }

        @keyframes pulse { 0% { transform: scale(1); opacity: 0.8; } 100% { transform: scale(3); opacity: 0; } }

        .timeline-content { flex-grow: 1; }
        .timeline-title { font-size: 1.1rem; font-weight: 500; margin-bottom: 4px; }
        .timeline-date { font-size: 0.8rem; opacity: 0.6; font-family: sans-serif; }

        .tap-hint { font-size: 0.7rem; color: var(--color-accent); border: 1px solid var(--color-accent); padding: 4px 12px; border-radius: 20px; opacity: 0.5; transition: var(--transition); }

        /* Modal */
        .modal-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(40, 38, 35, 0.85); backdrop-filter: blur(8px); display: flex; align-items: center; justify-content: center; z-index: 9999; opacity: 0; visibility: hidden; transition: var(--transition); }
        .modal-overlay.active { opacity: 1; visibility: visible; }
        .modal-content { width: 90%; max-width: 450px; background: white; border-radius: 16px; overflow: hidden; position: relative; transform: scale(0.95); transition: var(--transition); }
        .modal-overlay.active .modal-content { transform: scale(1); }
        .modal-img-container { width: 100%; aspect-ratio: 3 / 2; background: #f8f8f8; display: flex; align-items: center; justify-content: center; overflow: hidden; }
        .modal-img-container img { width: 100%; height: 100%; object-fit: cover; }
        .modal-body { padding: 30px 25px; text-align: center; }
        .modal-title { font-size: 1.2rem; color: var(--color-accent); margin-bottom: 10px; font-weight: 700; }
        .modal-text { font-size: 0.95rem; line-height: 1.8; color: var(--color-text); white-space: pre-wrap; }
        .close-btn { position: absolute; top: 15px; right: 15px; width: 36px; height: 36px; background: rgba(255,255,255,0.8); border: none; border-radius: 50%; font-size: 24px; cursor: pointer; display: flex; align-items: center; justify-content: center; z-index: 10001; }

        body.modal-open { overflow: hidden; }
        @media (max-width: 480px) { .tap-hint { display: none; } }
    </style>
</head>
<body>

    <div class="section-timeline fade-in">
        <header class="section-header">
            <!-- メインタイトル -->
            <h1 id="mainTitle">Our Story</h1>
            <!-- サブタイトル -->
            <p id="subTitle">ふたりの歩み</p>
        </header>

        <!-- タイムライン項目がここに自動生成されます -->
        <div class="timeline-container" id="timelineContainer">
            <div class="timeline-line"></div>
        </div>
    </div>

    <!-- Modal -->
    <div id="storyModal" class="modal-overlay" onclick="closeModal()">
        <div class="modal-content" onclick="event.stopPropagation()">
            <button class="close-btn" onclick="closeModal()">&times;</button>
            <div class="modal-img-container">
                <img id="modalImg" src="" alt="Memory" style="display:none;" onload="this.style.display='block'">
            </div>
            <div class="modal-body">
                <h3 id="modalTitle" class="modal-title"></h3>
                <p id="modalDesc" class="modal-text"></p>
            </div>
        </div>
    </div>

    <script>
        // ==========================================
        // --- 編集エリア：ここを変えるだけで文字が変わります ---
        // ==========================================
        
        const config = {
            mainTitle: "Our Story",
            subTitle: "ふたりのこれまでの歩み",
            tapLabel: "詳しく見る" // ボタンの文字
        };

        const storyData = [
            {
                date: "2018.04.12",
                title: "運命の出会い",
                desc: "桜が満開の春の日、私たちは初めて出会いました。\nここからすべての物語が始まりました。",
                img: "https://images.unsplash.com/photo-1511795409834-ef04bbd61622?w=800"
            },
            {
                date: "2018.06.20",
                title: "初めてのデート",
                desc: "緊張しながら歩いた横浜の海沿い。\n夕日がとても綺麗だったのを覚えています。",
                img: "https://images.unsplash.com/photo-1516483638261-f4dbaf036963?w=800"
            },
            {
                date: "2023.08.15",
                title: "プロポーズ",
                desc: "旅行先のレストランで。\nこれからの人生を共に歩むことを約束しました。",
                img: "https://images.unsplash.com/photo-1515934751635-c81c6bc9a2d8?w=800"
            }
        ];

        // ==========================================
        // --- 処理エリア：ここから下は触らなくてOKです ---
        // ==========================================

        document.getElementById('mainTitle').textContent = config.mainTitle;
        document.getElementById('subTitle').textContent = config.subTitle;

        const container = document.getElementById('timelineContainer');
        storyData.forEach((item, index) => {
            const itemHtml = `
                <div class="timeline-item" onclick="openStoryModal(${index})" tabindex="0" role="button">
                    <span class="timeline-marker"></span>
                    <div class="timeline-content">
                        <h3 class="timeline-title">${item.title}</h3>
                        <p class="timeline-date">${item.date}</p>
                    </div>
                    <div class="tap-hint">${config.tapLabel}</div>
                </div>
            `;
            container.insertAdjacentHTML('beforeend', itemHtml);
        });

        function openStoryModal(index) {
            const data = storyData[index];
            const modal = document.getElementById('storyModal');
            document.getElementById('modalImg').src = data.img;
            document.getElementById('modalTitle').textContent = data.title;
            document.getElementById('modalDesc').textContent = data.desc;
            modal.classList.add('active');
            document.body.classList.add('modal-open');
        }

        function closeModal() {
            document.getElementById('storyModal').classList.remove('active');
            document.body.classList.remove('modal-open');
        }

        document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });
    </script>
</body>
</html>
